{
  "extends": "./tsconfig.build.json",
  "exclude": [],
  "compilerOptions": {
    "rootDir": ".",
    "module": "esnext"
  },
  "include": [
    "source/**/*.ts",
    "source/**/*.js",
    "source/**/*.json",
    "source/**/*.d.ts",
    "source/**/*.mts",
    "source/**/*.cts",
    "source/**/*.mtsx",
    "source/**/*.ctsx",
    "source/**/*.mjs",
    "source/**/*.cjs",
    "source/**/*.mjsx",
    "source/**/*.cjsx",
    "types/**/*.d.ts",
    "scripts/**/*.ts",
    "eslint.config.mts"
  ],
  "files": ["eslint.config.mts", "prisma.config.ts", "capacitor.config.ts"]
}
