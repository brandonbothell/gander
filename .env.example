JWT_SECRET = "example_jwt_secret"

API_ENV = "development"
CAPACITOR_ENV = "production"
DEBUG_MOTION = "false"

VITE_GOOGLE_MAPS_API_KEY = "example_google_maps_api_key"
VITE_BASE_URL = "http://localhost:3000"
VITE_REACT_APP_VERSION = "1.0.0"
